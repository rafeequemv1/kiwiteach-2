# Copy to `.env` in this folder for local dev. Never commit `.env`.
# Vercel: add the same keys under Project → Settings → Environment Variables.

# Google Gemini (browser bundle — use VITE_ prefix)
VITE_GEMINI_API_KEY=
# Optional aliases (same value as above, if you use a different naming convention)
# VITE_GOOGLE_GENAI_API_KEY=
# VITE_GEMINI_KEY=

# Supabase (anon key is public to the client; security = RLS + policies)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Canonical frontend origin for auth redirects (e.g. https://www.kiwiteach.com)
VITE_SITE_URL=

# Optional legacy alias for Gemini (prefer VITE_GEMINI_API_KEY)
# VITE_API_KEY=

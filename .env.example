# Copy to `.env` in this folder for local dev. Never commit `.env`.
# Vercel: add the same keys under Project → Settings → Environment Variables.

# Google Gemini — server only (used by /api/gemini). Do NOT prefix with VITE_.
GEMINI_API_KEY=
# Optional alias:
# GOOGLE_GENAI_API_KEY=

# Supabase — serverless /api/gemini validates the user JWT; use same project as the app.
# You can set either names (Vercel often has VITE_* from the frontend); api/gemini reads both.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-only: used by /api/dodo-webhook to upsert payments/subscriptions (bypasses RLS). Never VITE_* or client.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (anon key is public to the client; security = RLS + policies)
# Pricing page reads `marketing_pricing_plans` (INR) with anon — apply migration `20260507120000_marketing_pricing_plans_inr.sql`.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Dodo Payments (/api/dodo-webhook). Use live_mode or test_mode for DODO_PAYMENTS_ENVIRONMENT.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_WEBHOOK_KEY=

# Optional: `npm run dev` (Vite) cannot run /api/* locally. Run `vercel dev` in another terminal,
# then point Vite at that origin so /api/gemini is proxied (e.g. http://127.0.0.1:3000).
# VITE_VERCEL_DEV_API_ORIGIN=http://127.0.0.1:3000
# Canonical site URL for SEO / OG (set in Vercel Production to https://kiwiteach.com). Leave unset locally to use the dev server origin.
VITE_SITE_URL=

